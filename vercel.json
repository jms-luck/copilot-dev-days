{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "framework": "vite",
  "functions": {
    "api": "api"
  },
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/:path*",
      "destination": "/:path*",
      "permanent": true,
      "regex": "^/api(/.*)?$"
    }
  ]
}
